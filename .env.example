# Copy this file to `.env` and fill in the values:
#   cp .env.example .env
#
# Only GCP_PROJECT and PULL_SECRET_PATH are required; everything else has a
# sensible default. The .env file is git-ignored — never commit it.

# ─── GCP target ────────────────────────────────────────────────────────────
# Required. Existing GCP project ID where the VM will be created.
GCP_PROJECT=

# Zone must support n2 machines AND nested virtualization.
GCP_ZONE=us-central1-a

# Name of the Compute Engine instance.
VM_NAME=openshift-test-bench

# ─── VM shape ──────────────────────────────────────────────────────────────
# n2-standard-16 = 16 vCPU / 64 GB RAM. CRC needs ~9 vCPU / 9 GB minimum;
# this leaves comfortable headroom for nested KVM + your workloads.
MACHINE_TYPE=n2-standard-16

# Required for nested virt on n2. Cascade Lake or newer. Quote the value —
# it contains spaces.
MIN_CPU_PLATFORM="Intel Cascade Lake"

BOOT_DISK_SIZE=200GB
BOOT_DISK_TYPE=pd-ssd

# Spot VM: ~60–91% cheaper than on-demand, but GCP can preempt the instance
# at any time with ~30s notice. On preemption the VM AND its boot disk are
# deleted (--instance-termination-action=DELETE) — you'll re-run scripts
# 01→03 from scratch. Leave `false` for a normal (STANDARD) VM.
ENABLE_SPOT_VM=false

# Rocky Linux 9 is the default because CRC officially supports RHEL-family
# hosts. Override to (e.g.) `fedora-cloud` / `fedora-cloud` or
# `debian-12` / `debian-cloud` at your own risk — `crc setup` may need extra
# packages on non-RHEL hosts.
IMAGE_FAMILY=rocky-linux-9-optimized-gcp
IMAGE_PROJECT=rocky-linux-cloud

# SSH user. Leave blank to let gcloud OS Login pick your account; otherwise
# set to a specific Linux username.
SSH_USER=

# ─── Red Hat pull secret ───────────────────────────────────────────────────
# Required. Absolute path on YOUR LAPTOP to the pull-secret.json downloaded
# from https://console.redhat.com/openshift/create/local
# The file is scp'd to the VM during bootstrap; never inlined into env vars.
PULL_SECRET_PATH=

# ─── CRC ──────────────────────────────────────────────────────────────────
# `latest` resolves to the newest stable CRC release at bootstrap time.
# Pin to e.g. `2.46.0` for reproducibility.
CRC_VERSION=latest

# Resources the CRC VM-inside-VM will claim. Keep below MACHINE_TYPE limits.
CRC_CPUS=12
CRC_MEMORY_MIB=32768
CRC_DISK_GIB=80

# `openshift` (default), `microshift`, or `okd`.
CRC_PRESET=openshift

# ─── Helm ──────────────────────────────────────────────────────────────────
# Helm v3 is installed on the VM during bootstrap. `latest` follows the
# get.helm.sh installer; pin to e.g. `v3.16.2` for reproducibility.
HELM_VERSION=latest

# ─── Optional: laptop-side SSH tunnel (only used by 04-tunnel.sh) ──────────
# Override if a port is already in use locally. Note that 80/443 require
# sudo on most laptops.
LOCAL_API_PORT=6443
LOCAL_HTTP_PORT=80
LOCAL_HTTPS_PORT=443
